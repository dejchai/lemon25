{
    "manifest_version": 3,
    "name": "AI Stacks Collector",
    "version": "1.0",
    "description": "Automatically capture and organize text copied from AI chat interfaces",
    "permissions": [
        "storage",
        "activeTab",
        "contextMenus",
        "clipboardWrite"
    ],
    "host_permissions": [
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://claude.ai/*",
        "https://copilot.microsoft.com/*",
        "file:///*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://chat.openai.com/*",
                "https://chatgpt.com/*",
                "https://gemini.google.com/*",
                "https://claude.ai/*",
                "https://copilot.microsoft.com/*",
                "file:///*"
            ],
            "js": ["contentScript.js"],
            "run_at": "document_start"
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png",
        "256": "icons/icon256.png",
        "512": "icons/icon512.png"
    }
}
